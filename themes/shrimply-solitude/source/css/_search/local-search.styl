.search-dialog
  position fixed
  top 50%
  left 50%
  transform translate(-50%, -50%)
  z-index 1001
  display none
  flex-direction column
  width 520px
  max-width 92vw
  background var(--sb-card-bg)
  border-radius 18px
  box-shadow 0 20px 60px rgba(0,0,0,.25), 0 0 0 1px rgba(0,0,0,.06)
  padding 28px 32px
  animation fadeInUp .35s cubic-bezier(.4,0,.2,1)

  +maxWidth768()
    top auto
    bottom 0
    left 0
    transform none
    width 100%
    max-width 100%
    border-radius 20px 20px 0 0
    padding 24px 20px 36px
    animation slideUp .3s ease

  &:hover
    box-shadow 0 20px 60px rgba(0,0,0,.25), 0 0 0 1px rgba(0,0,0,.06)

  .search-dialog-title
    font-weight 700
    font-size 1.15em
    color var(--sb-fontcolor)
    letter-spacing .3px

  .search-close-button
    width 32px
    height 32px
    display flex
    align-items center
    justify-content center
    border-radius 50%
    background var(--sb-secondbg)
    color var(--sb-secondtext)
    font-size 1em
    cursor pointer
    transition all .2s

    &:hover
      background var(--sb-main)
      color #fff

  #search-results
    max-height 340px
    overflow-y auto
    margin-top 12px
    display flex
    flex-direction column
    gap 4px

    .search-result-item
      padding 0

      .search-result-title
        display block
        padding 10px 14px
        border-radius 10px
        font-size 14px
        font-weight 600
        color var(--sb-fontcolor)
        transition all .2s
        white-space nowrap
        overflow hidden
        text-overflow ellipsis

        &:hover
          background var(--sb-secondbg)
          color var(--sb-main)

        em
          color var(--sb-main)
          font-weight 800
          font-style normal
          background var(--sb-main-op-light)
          padding 0 2px
          border-radius 3px

    .search-result-empty
      display block
      text-align center
      padding 32px 0
      font-size 14px
      color var(--sb-secondtext)

    +maxWidth768()
      max-height 55vh

  #search-pagination
    margin-top 8px

    .pagination-list
      display flex
      justify-content center
      gap 6px
      padding 0

      .pagination-item
        min-width 32px
        height 32px
        display flex
        align-items center
        justify-content center
        border-radius 8px
        font-size 13px
        font-weight 600
        color var(--sb-secondtext)
        cursor pointer
        transition all .2s

        &:hover
          background var(--sb-secondbg)
          color var(--sb-main)

        &.select
          background var(--sb-main)
          color #fff

  #search-tips
    margin-top 8px
    text-align center

    .search-result-count
      font-size 12px
      color var(--sb-secondtext)
      opacity .7

  .search-box
    width 100%
    margin-top 12px

    input
      width 100%
      height 46px
      border-radius 12px
      border 2px solid var(--sb-secondbg)
      background var(--sb-secondbg)
      padding 0 16px
      font-size 15px
      color var(--sb-fontcolor)
      outline none
      transition all .25s

      &:focus
        border-color var(--sb-main)
        background var(--sb-card-bg)
        box-shadow 0 0 0 4px var(--sb-main-op)

      &::placeholder
        color var(--sb-secondtext)
        opacity .6

#search-mask
  position fixed
  inset 0
  z-index 1000
  display none
  background rgba(0,0,0,.55)
  backdrop-filter blur(16px)
  -webkit-backdrop-filter blur(16px)
  animation fadeIn .3s ease

.search-nav
  display flex
  justify-content space-between
  align-items center

@keyframes fadeInUp
  from
    opacity 0
    transform translate(-50%, -40%)
  to
    opacity 1
    transform translate(-50%, -50%)

@keyframes slideUp
  from
    transform translateY(100%)
  to
    transform translateY(0)

@keyframes fadeIn
  from
    opacity 0
  to
    opacity 1
