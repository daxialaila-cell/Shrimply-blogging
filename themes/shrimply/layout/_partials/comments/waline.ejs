<% if (theme.waline.serverURL) { %>
  <div id="waline"></div>
  <script type="module">
    Shrimply.utils.loadComments('#waline', function() {
      Shrimply.utils.createCssLink('<%= url_join(theme.static_prefix.waline, 'waline.css') %>')
      import('<%= url_join(theme.static_prefix.waline, 'waline.js') %>').then(({ init }) => {
        var options = Object.assign(
          <%- JSON.stringify(theme.waline || {}) %>,
          {
            el: '#waline',
            path: <%= theme.waline.path %>
          }
        )
        init(options);
        Shrimply.utils.waitElementVisible('#waline .vcontent', () => {
          var imgSelector = '#waline .vcontent img:not(.vemoji)';
          Shrimply.plugins.imageCaption(imgSelector);
          Shrimply.plugins.fancyBox(imgSelector);
        })
      });
    });
  </script>
  <noscript>Please enable JavaScript to view the comments</noscript>
<% } %>
