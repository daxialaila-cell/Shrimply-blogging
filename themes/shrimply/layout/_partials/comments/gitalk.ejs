<% if(theme.gitalk.clientID && theme.gitalk.clientSecret && theme.gitalk.repo){ %>
  <div id="gitalk-container"></div>
  <script type="text/javascript">
    Shrimply.utils.loadComments('#gitalk-container', function() {
      Shrimply.utils.createCssLink('<%= url_join(theme.static_prefix.internal_css, 'gitalk.css') %>')
      Shrimply.utils.createScript('<%= url_join(theme.static_prefix.gitalk, 'gitalk.min.js') %>', function() {
        var options = Object.assign(
          <%- JSON.stringify(theme.gitalk || {}) %>,
          {
            id: '<%= md5(page.path) %>'
          }
        )
        var gitalk = new Gitalk(options);
        gitalk.render('gitalk-container');
      });
    });
  </script>
  <noscript>Please enable JavaScript to view the comments</noscript>
<% } %>
